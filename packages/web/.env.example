# Copy to .env and tweak per environment.
# Vite only exposes vars prefixed with VITE_ to the client bundle.

# Where the React app should send API requests.
# Local dev: leave as the localhost default below (or omit the file entirely).
# Production: set to https://your-api.example.com/api
VITE_API_BASE_URL=http://localhost:3001/api
