generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum ContentType {
  VIDEO
  DOCUMENT
  QUIZ
  PRACTICE
}

enum EnrollmentType {
  TRIAL
  PAID
}

enum PayoutStatus {
  HELD
  PAID
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model User {
  id             Int     @id @default(autoincrement())
  email          String  @unique
  username       String  @unique
  hashedPassword String
  firstName      String?
  lastName       String?
  role           Role    @default(STUDENT)

  stripeCustomerId      String? @unique
  stripePaymentMethodId String?

  coursesAsTeacher Course[]      @relation("TeacherCourses")
  enrollments      Enrollment[]
  quizAttempts     QuizAttempt[]
  payments         Payment[]
  reviews          Review[]
  comments         Comment[]
  practiceSubmissions PracticeSubmission[]
  contentCompletions  ContentCompletion[]
  projectSubmissions  ProjectSubmission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  courses Course[]
}

model Course {
  id                 Int          @id @default(autoincrement())
  title              String
  description        String
  price              Float
  trialDurationDays  Int?
  accessDurationDays Int?
  level              CourseLevel?

  teacherId Int
  teacher   User @relation("TeacherCourses", fields: [teacherId], references: [id])

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  modules     Module[]
  enrollments Enrollment[]
  projects    Project[]

  // Self-many-to-many: courses this course requires the student to have done first.
  prerequisites Course[] @relation("CoursePrerequisites")
  prerequisiteOf Course[] @relation("CoursePrerequisites")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Module {
  id    Int    @id @default(autoincrement())
  title String
  order Int

  courseId Int
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  contents Content[]
}

model Content {
  id                 Int         @id @default(autoincrement())
  title              String
  order              Int
  contentType        ContentType
  videoUrl           String?
  durationInSeconds  Int?
  documentUrl        String?
  fileType           String?
  timeLimitInMinutes Int?
  isFreePreview      Boolean     @default(false)

  moduleId Int
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  questions    Question[]
  quizAttempts QuizAttempt[]
  comments     Comment[]
  practice     Practice?
  completions  ContentCompletion[]
}

model Project {
  id           Int      @id @default(autoincrement())
  courseId     Int
  course       Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title        String
  description  String
  requirements String?
  deadline     DateTime?

  submissions  ProjectSubmission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courseId])
}

model ProjectSubmission {
  id              Int       @id @default(autoincrement())
  projectId       Int
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  studentId       Int
  student         User      @relation(fields: [studentId], references: [id])

  repoUrl         String
  commitsJson     Json?
  lastFetchedAt   DateTime?

  teacherFeedback String?
  teacherGrade    Int?

  submittedAt     DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([studentId, projectId])
  @@index([projectId])
}

model ContentCompletion {
  id          Int      @id @default(autoincrement())
  studentId   Int
  student     User     @relation(fields: [studentId], references: [id])
  contentId   Int
  content     Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  completedAt DateTime @default(now())

  @@unique([studentId, contentId])
  @@index([studentId])
}

model Practice {
  id             Int      @id @default(autoincrement())
  contentId      Int      @unique
  content        Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  prompt         String
  starterCode    String?
  expectedOutput String?
  language       String   @default("plaintext")

  submissions    PracticeSubmission[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PracticeSubmission {
  id             Int      @id @default(autoincrement())

  practiceId     Int
  practice       Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  studentId      Int
  student        User     @relation(fields: [studentId], references: [id])

  submittedCode  String
  aiScore        Float?
  aiFeedback     String?

  createdAt      DateTime @default(now())

  @@index([studentId, practiceId, createdAt])
}

model Question {
  id           Int    @id @default(autoincrement())
  questionText String

  contentId Int
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  options AnswerOption[]
}

model AnswerOption {
  id         Int     @id @default(autoincrement())
  optionText String
  isCorrect  Boolean

  questionId Int
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id             Int       @id @default(autoincrement())
  enrollmentDate DateTime  @default(now())
  progress       Float     @default(0)
  completionDate DateTime?

  type                 EnrollmentType @default(PAID)
  expiresAt            DateTime?
  trialCardFingerprint String?
  isActive             Boolean        @default(true)

  studentId Int
  student   User @relation(fields: [studentId], references: [id])

  courseId Int
  course   Course @relation(fields: [courseId], references: [id])

  payment Payment? @relation("EnrollmentPayment")
  review  Review?  @relation("EnrollmentReview")

  @@unique([studentId, courseId])
  @@index([trialCardFingerprint, courseId])
}

model Review {
  id         Int      @id @default(autoincrement())
  rating     Int
  comment    String?
  datePosted DateTime @default(now())

  enrollmentId Int        @unique
  enrollment   Enrollment @relation("EnrollmentReview", fields: [enrollmentId], references: [id])

  studentId Int
  student   User @relation(fields: [studentId], references: [id])
}

model QuizAttempt {
  id        Int      @id @default(autoincrement())
  score     Float
  startTime DateTime
  endTime   DateTime

  studentId Int
  student   User @relation(fields: [studentId], references: [id])

  quizContentId Int
  quizContent   Content @relation(fields: [quizContentId], references: [id])
}

model Payment {
  id              Int    @id @default(autoincrement())
  amount          Float
  status          String
  stripeSessionId String @unique

  enrollmentId Int        @unique
  enrollment   Enrollment @relation("EnrollmentPayment", fields: [enrollmentId], references: [id])

  studentId Int
  student   User @relation(fields: [studentId], references: [id])

  revenueLedger RevenueLedger?

  createdAt DateTime @default(now())
}

model RevenueLedger {
  id           Int          @id @default(autoincrement())
  paymentId    Int          @unique
  payment      Payment      @relation(fields: [paymentId], references: [id])

  courseId     Int
  teacherId    Int

  grossAmount  Float
  platformFee  Float
  teacherShare Float

  payoutStatus PayoutStatus @default(HELD)
  paidAt       DateTime?

  createdAt    DateTime     @default(now())

  @@index([teacherId, createdAt])
  @@index([payoutStatus])
}

model Comment {
  id   Int    @id @default(autoincrement())
  text String

  authorId Int
  author   User @relation(fields: [authorId], references: [id])

  contentId Int
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  parentId Int?
  parent   Comment?  @relation("Replies", fields: [parentId], references: [id])
  replies  Comment[] @relation("Replies")

  createdAt DateTime @default(now())
}
