generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum ContentType {
  VIDEO
  DOCUMENT
  QUIZ
  PRACTICE
}

enum VideoQuizBlockingMode {
  PAUSE        @map("pause")
  NON_BLOCKING @map("non-blocking")
}

enum EnrollmentType {
  TRIAL
  PAID
  FREE
}

enum PayoutStatus {
  HELD
  PAID
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model User {
  id             Int     @id @default(autoincrement())
  email          String  @unique
  username       String  @unique
  hashedPassword String
  firstName      String?
  lastName       String?
  role           Role    @default(STUDENT)

  isVerified              Boolean   @default(false)
  verificationToken       String?   @unique
  verificationTokenExpiry DateTime?

  resetToken       String?   @unique
  resetTokenExpiry DateTime?

  coursesAsTeacher   Course[]           @relation("TeacherCourses")
  enrollments        Enrollment[]
  quizAttempts       QuizAttempt[]
  payments           Payment[]
  reviews            Review[]
  comments           Comment[]
  practiceSubmissions PracticeSubmission[]
  projectSubmissions  ProjectSubmission[]
  revenueLedgers     RevenueLedger[]    @relation("TeacherLedger")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  courses Course[]
}

model Course {
  id                Int          @id @default(autoincrement())
  title             String
  description       String
  syllabus          Json         @default("{}")
  price             Float
  thumbnailUrl      String?
  // EPIC 1: trial support
  trialDurationDays Int?
  // EPIC 2: time-limit access
  accessDurationDays Int?
  // EPIC 5: learning path
  level             CourseLevel?

  teacherId Int
  teacher   User @relation("TeacherCourses", fields: [teacherId], references: [id])

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  // EPIC 5: self-relation prerequisites
  prerequisites   Course[] @relation("CoursePrerequisites")
  prerequisiteOf  Course[] @relation("CoursePrerequisites")

  modules        Module[]
  enrollments    Enrollment[]
  revenueLedgers RevenueLedger[]
  projects       Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Module {
  id    Int    @id @default(autoincrement())
  title String
  order Int

  courseId Int
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  contents Content[]
}

model Content {
  id                 Int         @id @default(autoincrement())
  title              String
  order              Int
  contentType        ContentType
  videoUrl           String?
  durationInSeconds  Int?
  documentUrl        String?
  fileType           String?
  timeLimitInMinutes Int?
  // EPIC 1: free preview for guests
  isFreePreview      Boolean     @default(false)

  moduleId Int
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  questions         Question[]
  quizAttempts      QuizAttempt[]
  comments          Comment[]
  contentProgresses ContentProgress[]
  videoQuizMarkers  VideoQuizMarker[]
  practice          Practice?
}

model Question {
  id           Int    @id @default(autoincrement())
  questionText String

  contentId Int
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  options          AnswerOption[]
  videoQuizMarkers VideoQuizMarker[]
}

model AnswerOption {
  id         Int     @id @default(autoincrement())
  optionText String
  isCorrect  Boolean

  questionId Int
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id             Int            @id @default(autoincrement())
  enrollmentDate DateTime       @default(now())
  progress       Float          @default(0)
  completionDate DateTime?
  // EPIC 1: trial vs paid
  type           EnrollmentType @default(PAID)
  // EPIC 2: expiry
  expiresAt      DateTime?
  isActive       Boolean        @default(true)

  studentId Int
  student   User @relation(fields: [studentId], references: [id])

  courseId Int
  course   Course @relation(fields: [courseId], references: [id])

  payment           Payment?          @relation("EnrollmentPayment")
  review            Review?           @relation("EnrollmentReview")
  contentProgresses ContentProgress[]
  revenueLedger     RevenueLedger?

  @@unique([studentId, courseId])
  @@index([isActive, expiresAt])
  @@index([studentId, isActive])
}

model ContentProgress {
  id          Int      @id @default(autoincrement())
  completedAt DateTime @default(now())
  // EPIC 7: for video, track watch percentage
  watchedSeconds Int?

  enrollmentId Int
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  contentId Int
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, contentId])
}

model Review {
  id         Int      @id @default(autoincrement())
  rating     Int
  comment    String?
  datePosted DateTime @default(now())

  enrollmentId Int        @unique
  enrollment   Enrollment @relation("EnrollmentReview", fields: [enrollmentId], references: [id])

  studentId Int
  student   User @relation(fields: [studentId], references: [id])
}

model QuizAttempt {
  id        Int      @id @default(autoincrement())
  score     Float
  startTime DateTime
  endTime   DateTime

  studentId Int
  student   User @relation(fields: [studentId], references: [id])

  quizContentId Int
  quizContent   Content @relation(fields: [quizContentId], references: [id])
}

model VideoQuizMarker {
  id           Int                   @id @default(autoincrement())
  contentId    Int
  content      Content               @relation(fields: [contentId], references: [id], onDelete: Cascade)
  timestampSec Int
  questionId   Int
  question     Question              @relation(fields: [questionId], references: [id], onDelete: Cascade)
  blockingMode VideoQuizBlockingMode @default(PAUSE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contentId, timestampSec, questionId])
  @@index([contentId, timestampSec])
  @@index([questionId])
}

// EPIC 3: Practice alongside theory
model Practice {
  id             Int     @id @default(autoincrement())
  prompt         String
  starterCode    String?
  expectedOutput String?
  rubric         String?
  language       String  @default("javascript")

  contentId Int     @unique
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  submissions PracticeSubmission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PracticeSubmission {
  id            Int      @id @default(autoincrement())
  submittedCode String
  aiFeedback    String?
  score         Float?
  passed        Boolean  @default(false)
  submittedAt   DateTime @default(now())

  studentId  Int
  student    User     @relation(fields: [studentId], references: [id])
  practiceId Int
  practice   Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@index([studentId, practiceId])
}

model Payment {
  id              Int    @id @default(autoincrement())
  amount          Float
  status          String
  stripeSessionId String @unique

  enrollmentId Int        @unique
  enrollment   Enrollment @relation("EnrollmentPayment", fields: [enrollmentId], references: [id])

  studentId Int
  student   User @relation(fields: [studentId], references: [id])

  revenueLedger RevenueLedger?

  createdAt DateTime @default(now())
}

// EPIC 4: Revenue Ledger
model RevenueLedger {
  id           Int          @id @default(autoincrement())
  grossAmount  Float
  platformFee  Float
  teacherShare Float
  payoutStatus PayoutStatus @default(HELD)
  paidAt       DateTime?

  paymentId Int     @unique
  payment   Payment @relation(fields: [paymentId], references: [id])

  enrollmentId Int        @unique
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id])

  courseId Int
  course   Course @relation(fields: [courseId], references: [id])

  teacherId Int
  teacher   User  @relation("TeacherLedger", fields: [teacherId], references: [id])

  createdAt DateTime @default(now())

  @@index([teacherId, payoutStatus])
  @@index([courseId])
  @@index([createdAt])
}

model Comment {
  id   Int    @id @default(autoincrement())
  text String

  authorId Int
  author   User @relation(fields: [authorId], references: [id])

  contentId Int
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  parentId Int?
  parent   Comment?  @relation("Replies", fields: [parentId], references: [id])
  replies  Comment[] @relation("Replies")

  createdAt DateTime @default(now())
}

model Promotion {
  id                Int       @id @default(autoincrement())
  code              String    @unique
  description       String?
  discountType      String
  discountValue     Float
  minPurchaseAmount Float?
  maxDiscountAmount Float?
  usageLimit        Int?
  usedCount         Int       @default(0)
  startDate         DateTime
  endDate           DateTime
  isActive          Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// EPIC 6: Project-based Learning
model Project {
  id           Int       @id @default(autoincrement())
  title        String
  description  String
  requirements String
  deadline     DateTime?

  courseId Int
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  submissions ProjectSubmission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectSubmission {
  id            Int    @id @default(autoincrement())
  repoUrl       String
  commitHistory Json   @default("[]")
  feedback      String?
  grade         Float?
  submittedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  projectId Int
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  studentId Int
  student   User @relation(fields: [studentId], references: [id])

  @@unique([projectId, studentId])
  @@index([projectId])
  @@index([studentId])
}
